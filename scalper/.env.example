# ═══════════════════════════════════════════════════════════════════
# SCALPER PRO - Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# ── Dhan API ──────────────────────────────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# ── Telegram Bot ──────────────────────────────────────────────────
# 1. Open Telegram, search @BotFather
# 2. Send /newbot, follow prompts to create bot
# 3. Copy the token below
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 4. Start a chat with your bot
# 5. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 6. Send any message to the bot, refresh the URL
# 7. Find "chat":{"id": XXXXXXX} — that's your chat_id
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
